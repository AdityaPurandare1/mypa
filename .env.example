# myPA client environment.
# Copy to .env.local and fill in from your Supabase project's API settings.
# These are the ONLY secrets the client needs. The Anthropic API key lives
# server-side in the parse-task edge function — never here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional. Overrides the GitHub Pages base path. Defaults to /mypa/ on build,
# / in dev. Set to / if you host at a domain root.
# VITE_BASE=/mypa/
